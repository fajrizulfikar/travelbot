# LLM Provider: "claude" or "openai"
LLM_PROVIDER=claude

# Required if LLM_PROVIDER=claude
CLAUDE_API_KEY=

# Required if LLM_PROVIDER=openai or for embeddings
OPENAI_API_KEY=

# Vector store: "chroma"
VECTOR_STORE_BACKEND=chroma

# ChromaDB persistence directory. Use ":memory:" for tests
CHROMA_PERSIST_DIR=./data/chroma

# Escalation trigger: retrieval score below this threshold
CONFIDENCE_THRESHOLD=0.60

# Retrieval: minimum similarity score to include a chunk
SIMILARITY_THRESHOLD=0.70

# Number of top results to retrieve
TOP_N_RESULTS=5

# Maximum file size for uploads (MB)
MAX_FILE_SIZE_MB=50

# Logging level
LOG_LEVEL=INFO

# CORS allowed origins (comma-separated or JSON list)
CORS_ORIGINS=["*"]
